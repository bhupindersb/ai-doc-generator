# =============================================
# AI DOC GENERATOR — Environment Variables
# Copy this file to .env.local and fill in values
# =============================================

# --- ANTHROPIC (Claude API) ---
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# --- RAZORPAY ---
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
# Get from: https://dashboard.razorpay.com/app/webhooks (set secret when creating webhook)
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx
# Plan IDs — create plans in Razorpay Dashboard > Subscriptions > Plans
RAZORPAY_PLAN_SOLO=plan_xxxxxxxxxxxx
RAZORPAY_PLAN_TEAM=plan_xxxxxxxxxxxx
# Public key (safe to expose to browser)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx

# --- SUPABASE (Database) ---
# Get from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=xxxxxxxxxxxxxxxxxxxx
# Get from: https://supabase.com/dashboard/project/_/settings/database
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# --- NEXTAUTH ---
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=xxxxxxxxxxxxxxxxxxxx
NEXTAUTH_URL=http://localhost:3000

# --- GITHUB OAUTH (for "Sign in with GitHub") ---
# Get from: https://github.com/settings/developers > New OAuth App
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=xxxxxxxxxxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxx

# --- APP CONFIG ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="DocAI"
